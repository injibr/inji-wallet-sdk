{
  "name": "vc-sdk-headless",
  "version": "1.0.0",
  "description": "Headless Verifiable Credentials SDK for React Native - Pure logic layer with event-based API (no UI components)",
  "main": "./lib/module/index.js",
  "react-native": "./lib/module/index.js",
  "types": "./lib/typescript/index.d.ts",
  "files": [
    "src",
    "lib",
    "!**/__tests__",
    "!**/__fixtures__",
    "!**/__mocks__",
    "!**/.*"
  ],
  "scripts": {
    "test": "jest",
    "test:coverage": "jest --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"**/*.{js,ts,tsx}\"",
    "clean": "del-cli lib",
    "prepare": "bob build --target module",
    "build": "bob build",
    "build:docs": "typedoc src --out docs/api"
  },
  "keywords": [
    "verifiable-credentials",
    "digital-identity",
    "react-native",
    "headless",
    "sdk",
    "event-driven",
    "credentials",
    "identity",
    "security",
    "DID",
    "VP",
    "VC",
    "OpenID4VC",
    "OpenID4VP",
    "wallet"
  ],
  "author": "VC SDK Team <pankajchaudhary7121994@gmail.com>",
  "license": "MIT",
  "dependencies": {
    "@digitalcredentials/vc": "^1.1.2",
    "@noble/ed25519": "^2.1.0",
    "@noble/hashes": "^1.8.0",
    "@noble/secp256k1": "^2.3.0",
    "base64url-universal": "^1.1.0",
    "buffer": "^6.0.3",
    "color-diff": "^1.4.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^2.26.0",
    "elliptic": "^6.6.1",
    "eventemitter3": "^5.0.1",
    "jose": "^6.1.0",
    "jsonpath-plus": "^10.0.0",
    "jwt-decode": "^3.1.2",
    "node-forge": "^1.3.1",
    "react-native-get-random-values": "^1.11.0",
    "short-unique-id": "^4.4.4",
    "uuid": "^11.0.3",
    "xstate": "^4.35.0"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=1.17.0",
    "@react-native-community/netinfo": ">=9.0.0",
    "expo-crypto": ">=13.0.0",
    "react-native-device-info": ">=8.0.0",
    "react-native-fs": ">=2.18.0",
    "react-native-keychain": ">=8.0.0",
    "react-native-mmkv": ">=2.0.0"
  },
  "peerDependenciesMeta": {
    "expo-crypto": {
      "optional": true
    }
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.27.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.0.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.35.0",
    "jest": "^29.7.0",
    "prettier": "^3.6.2",
    "react-native-builder-bob": "^0.40.13",
    "typescript": "^5.9.2"
  },
  "jest": {
    "preset": "react-native",
    "modulePathIgnorePatterns": [
      "<rootDir>/lib/"
    ]
  },
  "prettier": {
    "quoteProps": "consistent",
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  },
  "react-native-builder-bob": {
    "source": "src",
    "output": "lib",
    "targets": [
      [
        "module",
        {
          "esm": true
        }
      ],
      [
        "typescript",
        {
          "project": "tsconfig.json"
        }
      ]
    ]
  }
}
